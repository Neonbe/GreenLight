    "onboarding.brand.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Detects and unblocks your apps — instantly."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "检测并解锁你的应用 — 即刻生效。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "偵測並解鎖你的應用程式 — 即刻生效。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリを検出してブロック解除 — 瞬時に。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앱을 감지하고 차단 해제 — 즉시."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Detecta y desbloquea tus apps — al instante."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Détecte et débloque vos apps — instantanément."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erkennt und entsperrt deine Apps — sofort."
          }
        }
      }
    },
