    "onboarding.launchAtLogin.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stay protected around the clock."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "全天候守护你的 Mac。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "全天候守護你的 Mac。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "24時間、Mac を守ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "24시간 Mac을 보호합니다."
