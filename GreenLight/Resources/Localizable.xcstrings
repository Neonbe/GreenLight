    "enhance.reason": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "GreenLight detected that macOS blocked an app, but couldn't fully verify where it's located."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "GreenLight 检测到 macOS 拦截了一个应用，但无法完全确认其位置。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "GreenLight 偵測到 macOS 攔截了一個應用程式，但無法完全確認其位置。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "GreenLight は macOS がアプリをブロックしたことを検出しましたが、場所を完全に確認できませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "GreenLight이 macOS가 앱을 차단한 것을 감지했지만, 위치를 완전히 확인할 수 없었습니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "GreenLight detectó que macOS bloqueó una app, pero no pudo verificar completamente su ubicación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "GreenLight a détecté que macOS a bloqué une app, mais n'a pas pu vérifier son emplacement."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "GreenLight hat erkannt, dass macOS eine App blockiert hat, konnte aber den Speicherort nicht vollständig überprüfen."
          }
        }
      }
    },
    "enhance.request": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Grant access to Downloads and Desktop for comprehensive monitoring — files are only scanned locally, nothing is uploaded or shared."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "授权访问「下载」和「桌面」文件夹以实现全面监控 — 文件仅在本地扫描，不会上传或分享。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "授權存取「下載項目」和「桌面」資料夾以實現全面監控 — 檔案僅在本機掃描，不會上傳或分享。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダウンロードとデスクトップへのアクセスを許可して包括的に監視します — ファイルはローカルでのみスキャンされ、アップロードや共有は一切ありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다운로드 및 데스크탑 폴더 접근을 허용하여 종합적으로 모니터링합니다 — 파일은 로컬에서만 스캔되며 업로드하거나 공유되지 않습니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Concede acceso a Descargas y Escritorio para supervisión completa — los archivos solo se analizan localmente, no se suben ni comparten."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Accordez l'accès aux Téléchargements et au Bureau pour une surveillance complète — les fichiers sont analysés uniquement en local, rien n'est envoyé ni partagé."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gewähre Zugriff auf Downloads und Schreibtisch für umfassende Überwachung — Dateien werden nur lokal gescannt, nichts wird hochgeladen oder geteilt."
          }
        }
      }
    },
