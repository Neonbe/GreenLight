    "onboarding.trust.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your privacy, first."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "隐私优先。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "隱私優先。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プライバシーを最優先に。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "개인정보 보호를 최우선으로."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu privacidad, primero."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre vie privée, d'abord."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Privatsphäre, zuerst."
          }
        }
      }
    },
    "onboarding.trust.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Runs offline · No data collected · Open source"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "离线运行 · 不收集数据 · 开源"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "離線運行 · 不收集資料 · 開源"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オフライン動作 · データ収集なし · オープンソース"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오프라인 작동 · 데이터 수집 없음 · 오픈 소스"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin conexión · Sin recopilación de datos · Código abierto"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fonctionne hors ligne · Aucune donnée collectée · Open source"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Läuft offline · Keine Datenerfassung · Open Source"
          }
        }
      }
    },
